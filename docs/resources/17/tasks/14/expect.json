{
    "intro": "setCardBeforeProps",
    "introTitle": "Добавьте карте `.card` псевдоэлемент `before` и задайте ему:",
    "assertions": [
        {
            "title": "содержание `A` (в латинской раскладке),",
            "name": "setCardPseudoElemContentToA",
            "expect": "expect(document).to.have.cssRule('.card::before', 'content', '\"A\"');"
        },
        {
            "title": "размер шрифта `30px`,",
            "name": "setCardPseudoElemFontSizeTo30Px",
            "expect": "expect(document).to.have.cssRule('.card::before', 'fontSize', '30px');"
        },
        {
            "title": "цвет текста `#e50000`.",
            "name": "setCardPseudoElemColorToRed",
            "expect": "expect(document).to.have.cssRule('.card::before', 'color', '#e50000');"
        }
    ]
}
