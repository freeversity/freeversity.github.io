{
    "introTitle": "Оберните в тег <code>:",
    "assertions": [
        {
            "title": "текст &lt;cite&gt;",
            "name": "wrapCiteTagWithCode",
            "expect": "expect(document.querySelector('article p:nth-of-type(1) code:first-of-type')).to.have.text('<cite>')"
        },
        {
            "title": "и текст &lt;blockquote&gt;.",
            "name": "wrapBlockquoteTagWithCode",
            "expect": "expect(document.querySelector('article p:nth-of-type(1) code:nth-of-type(2)')).to.have.text('<blockquote>')"
        }
    ]
}



