{
    "assertions": [
        {
            "title": "Добавьте текстовому полю идентификатор `total-field`",
            "name": "setInputIdToTotalField",
            "expect": "expect(document.querySelector('form input')).to.have.attr('id', 'total-field');"
        },
        {
            "title": "и значение по умолчанию `5`.",
            "name": "setInputValueTo5",
            "expect": "expect(document.querySelector('form input')).to.have.attr('value', '5');"
        }
    ]
}












