{
    "assertions": [
        {
            "title": "Добавьте в форму поле ввода с помощью тега `<input>`,",
            "name": "addInputToForm",
            "expect": "expect(document.querySelector('form input')).to.exist;"
        },
        {
            "title": "задайте ему тип `text`",
            "name": "setInputTypeToText",
            "expect": "expect(document.querySelector('form input')).to.have.attr('type', 'text');"
        },
        {
            "title": "и имя `login`.",
            "name": "setInputNameToLogin",
            "expect": "expect(document.querySelector('form input')).to.have.attr('name', 'login');"
        }
    ],
    "strict": true
}














