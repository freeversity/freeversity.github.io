{
    "assertions": [
        {
            "title": "Для `.deck img:hover` задайте `opacity` со значением `0.6`.",
            "name": "setDeckImgHoverOpacityTo0.6",
            "type": "action",
            "target": "img",
            "eventType": "mouseover",
            "debounce": 50,
            "expect": "expect(document).to.have.cssRule('.deck img:hover', 'opacity', '0.6');"
        },
        {
            "title": "А также увеличение `scale` до значения `1.1`.",
            "name": "setDeckImgHoverTransformToScale1.1",
            "type": "action",
            "target": "img",
            "eventType": "mouseover",
            "debounce": 50,
            "expect": "expect(document).to.have.cssRule('.deck img:hover', 'transform', 'scale(1.1)');"
        }
    ],
    "strict": true,
    "footnote": "hoverCardsAfterEachChange",
    "footnoteTitle": "После каждого изменения наводите курсор на любую карту для проверки."
}



