    "globalAssertion": "expect(document.querySelector('style[id=\"style.css\"]')).to.have.cssRule('.to-keksik', {marginLeft: '-120px'});expect(document.querySelector('style[id=\"style.css\"]')).to.have.cssRule('.to-rudolf', {marginLeft: '120px'});expect(document.querySelector('style[id=\"style.css\"]').sheet.rules).to.have.length(2)",
    "footnote": "youMustntChangeCssRules",
