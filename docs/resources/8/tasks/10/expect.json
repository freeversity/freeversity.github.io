{
    "assertions": [
        {
            "title": "Измените значение свойства `justify-content` на `flex-start`",
            "name": "setCardsListJustifyContentToFlexStart",
            "expect": "expect(document.querySelector('.cards-list')).to.have.css('justifyContent', 'flex-start');"
        },
        {
            "title": "Добавьте карточкам `card` внешние отступы справа и снизу `15px`. Карточки выстроятся по две в ряд.",
            "name": "setCardMarginLeftAndBottomTo15Px",
            "expect": "expect(document.querySelector('.card')).to.have.css('marginRight', '15px');expect(document.querySelector('.card')).to.have.css('marginBottom', '15px');"
        }
    ]
}



