{
    "assertions": [
        {
            "name": "addFeatureFurnitureToFirstP",
            "title": "Добавьте класс `feature-furniture` к первому тегу `<p>` раздела «Что поможет вам создать домашний уют?»",
            "expect": "expect(document.querySelector('.features p:first-of-type')).to.have.class('feature-furniture')"
        },
        {
            "name": "addFeatureLightingToSecondP",
            "title": "Теперь класс `feature-lighting` ко второму.",
            "expect": "expect(document.querySelector('.features p:nth-of-type(2)')).to.have.class('feature-lighting')"
        },
        {
            "name": "addFeatureAccessoriesToThirdP",
            "title": "И класс `feature-accessories` к третьему.",
            "expect": "expect(document.querySelector('.features p:nth-of-type(3)')).to.have.class('feature-accessories')"
        }
    ]
}
