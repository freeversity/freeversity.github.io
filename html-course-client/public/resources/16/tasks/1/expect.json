        },
        {
            "title": "третьему блоку — `#e74c3c`,",
            "name": "setThirdBlockBgColorToRed",
            "expect": "expect(document.querySelectorAll('.block3')).to.have.css('backgroundColor', '#e74c3c');"
        },
        {
            "title": "четвёртому блоку — `#e67e22`.",
            "name": "setFourthBlockBgColorToBrown",
            "expect": "expect(document.querySelectorAll('.block4')).to.have.css('backgroundColor', '#e67e22');"
        }
    ]
