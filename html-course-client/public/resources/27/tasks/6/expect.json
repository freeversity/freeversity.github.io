{
    "assertions": [
        {
            "title": "Блоку `.shadow-1` задайте фильтр `drop-shadow` со значением `15px 15px 15px black`,",
            "name": "setShadow1DropShadowTo15Px15px15PxBlack",
            "expect": "expect(document.querySelector('.shadow-1')).to.have.css('filter', 'drop-shadow(15px 15px 15px black)');"
        },
        {
            "title": "а блоку `.shadow-2` — со значением `drop-shadow(0px 0px 20px red)`.",
            "name": "setShadow2DropShadowTo0Px0px20PxRed",
            "expect": "expect(document.querySelector('.shadow-2')).to.have.css('filter', 'drop-shadow(0px 0px 20px red)');"
        }
    ]
}










