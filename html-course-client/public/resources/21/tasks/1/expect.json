{
    "assertions": [
        {
            "title": "Задайте всем лонгбордам `.skate`, на которых сидят еноты, ширину `75px` и высоту `300px` (минимальные размеры изменять не нужно),",
            "name": "setSkatWidthTo75PxAndHeight300Px",
            "expect": "expect(document.querySelectorAll('.skate')).to.have.css('width', '75px');expect(document.querySelectorAll('.skate')).to.have.css('height', '300px');"
        },
        {
            "title": "внутренние отступы со всех сторон `10px`.",
            "name": "setSkatePaddingTo10Px",
            "expect": "expect(document.querySelectorAll('.skate')).to.have.css('padding', '10px');"
        },
        {
            "title": "Затем второму скейту задайте `box-sizing: border-box`.",
            "name": "setSkate2BoxSizingToBorderBox",
            "expect": "expect(document.querySelector('.skate-2')).to.have.css('boxSizing', 'border-box');expect(document.querySelector('.skate:not(.skate-2)')).not.to.have.css('boxSizing', 'border-box');"
        }
    ],
    "strict": true
}




